                </noise>
            </ray>
        </sensor>
    </gazebo> -->

    <gazebo reference="gps_link">
        <sensor name="bunker_gps" type="gps">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <pose>0 0 0 0 0 0</pose>
            <gps>
                <position_sensing>
                    <horizontal>
                        <noise type="gaussian">
                        <mean>0</mean>
                        <stddev>0.00849</stddev>
                        </noise>
                    </horizontal>
                    <vertical>
                        <noise type="gaussian">
                        <mean>0</mean>
                        <stddev>0.00849</stddev>
                        </noise>
                    </vertical>
                </position_sensing>
            </gps>
            <plugin name="bunker_gps_plugin" filename="libgazebo_ros_gps_sensor.so">
                <ros>
                    <remapping>~/out:=/ublox_gps_node/fixx</remapping>
                </ros>
            </plugin>
        </sensor>
    </gazebo>
    <gazebo>
        <plugin name="bunker_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
        <ros>
            <!-- <namespace>/tb3</namespace> -->
            <remapping>~/out:=joint_states</remapping>
        </ros>
        <update_rate>30</update_rate>
            <!-- wheels -->
            <joint_name>base_left_wheel_rear_joint</joint_name>
            <joint_name>base_right_wheel_rear_joint</joint_name>

            <joint_name>base_left_wheel_front_joint</joint_name>
            <joint_name>base_right_wheel_front_joint</joint_name>
            
            <joint_name>base_left_wheel_middle_joint</joint_name>
            <joint_name>base_right_wheel_middle_joint</joint_name>

            <joint_name>base_left_wheel_front_2_joint</joint_name>
            <joint_name>base_right_wheel_front_2_joint</joint_name>

            <joint_name>base_left_wheel_rear_2_joint</joint_name>
            <joint_name>base_right_wheel_rear_2_joint</joint_name>

            <joint_name>base_left_wheel_front_4_joint</joint_name>
            <joint_name>base_right_wheel_front_4_joint</joint_name>

            <joint_name>base_left_wheel_rear_4_joint</joint_name>
            <joint_name>base_right_wheel_rear_4_joint</joint_name>

            <joint_name>base_left_wheel_front_43_joint</joint_name>
            <joint_name>base_right_wheel_front_43_joint</joint_name>

            <joint_name>base_left_wheel_rear_43_joint</joint_name>
            <joint_name>base_right_wheel_rear_43_joint</joint_name>

        </plugin>
    </gazebo>
</robot>



