<?xml version="1.0"?>

<robot name="bunker_mini"
  xmlns:xacro="http://ros.org/wiki/xacro">

    <!-- Define robot constants -->
    <xacro:property name="base_width" value="0.377"/>
    <xacro:property name="base_length" value="0.65475"/>
    <xacro:property name="base_height" value="0.2"/>

    <xacro:property name="wheel_radius" value="0.15" />
    <xacro:property name="wheel_length" value="0.1" />

    <xacro:property name="top_base_width" value="0.377"/>
    <xacro:property name="top_base_length" value="0.56"/>
    <xacro:property name="top_base_height" value="0.1092"/>

    <xacro:property name="tilt_lidar_base_radius" value="0.03" />
    <xacro:property name="tilt_lidar_base_length" value="0.0452" />
    <xacro:property name="base_tilt_lidar_base_x_offset" value="0.267375" />
    
    <xacro:property name="rplidar_radius" value="0.038" />
    <xacro:property name="rplidar_length" value="0.041" />
    <xacro:property name="rplidar_sensor_height" value="0.031" />


    <xacro:property name="gps_radius" value="0.03" />
    <xacro:property name="gps_length" value="0.01" />
    <xacro:property name="gps_sensor_height" value="0.0635" />

    <xacro:property name="top_base_to_top_sensor_x_offset" value="${(base_length-0.16)-(top_base_length/2)}" />

    <xacro:property name="track_width" value="0.1"/>
    <xacro:property name="track_length" value="${base_length*2/3.5}"/>
    <xacro:property name="track_height" value="${wheel_radius*2}"/>
    

    <xacro:macro name="wheel_link" params="prefix pos rpy">
        <link name="${prefix}_wheel_${pos}_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
                <material name="black" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0" />


                <collide_bitmask>0x10</collide_bitmask>
            </collision>
            <xacro:cylinder_inertia m="5" r="${wheel_radius}" h="${wheel_length}" xyz="0 0 0" rpy="${pi/2} 0 0" />
        </link>
    </xacro:macro>

    <xacro:macro name="wheel_link_f" params="prefix pos rpy">
        <link name="${prefix}_wheel_${pos}_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
                <material name="black" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0" />


                <collide_bitmask>0x10</collide_bitmask>
            </collision>
            <xacro:cylinder_inertia m="15" r="${wheel_radius}" h="${wheel_length}" xyz="0 0 0" rpy="${pi/2} 0 0" />
        </link>
    </xacro:macro>

    <link name="base_footprint" />

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
            <material name="white_mono" />
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="10" w="${base_width}" d="${base_length}" h="${base_height}" xyz="0 0 ${base_height/2}"/>
    </link>

    <!-- <link name="right_track_link">
        <visual>
            <geometry>
                <box size="${track_length} ${track_width} ${track_height}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="black" />
        </visual>
        <collision>
            <geometry>
                <box size="${track_length} ${track_width} ${track_height}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <collide_bitmask>0x01</collide_bitmask>

        </collision>
        <xacro:box_inertia m="10.0" w="${track_width}" d="${track_length}" h="${track_height}" xyz="0 0 0"/>
    </link> -->
<!-- 
    <link name="left_track_link">
        <visual>
            <geometry>
                <box size="${track_length} ${track_width} ${track_height}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="black" />
        </visual>
        <collision>
            <geometry>
                <box size="${track_length} ${track_width} ${track_height}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <collide_bitmask>0x01</collide_bitmask>
        </collision>
        <xacro:box_inertia m="10.0" w="${track_width}" d="${track_length}" h="${track_height}" xyz="0 0 0"/>
    </link> -->

    <link name="top_base_link">
        <visual>
            <geometry>
                <box size="${top_base_length} ${top_base_width} ${top_base_height}" />
            </geometry>
            <origin xyz="0 0 ${top_base_height/2}" rpy="0 0 0" />
            <material name="white_mono" />
        </visual>
        <collision>
            <geometry>
                <box size="${top_base_length} ${top_base_width} ${top_base_height}" />
            </geometry>
            <origin xyz="0 0 ${top_base_height/2}" rpy="0 0 0" />
        </collision>
    </link>

    <link name="tilt_lidar_base_link">
        <visual>
            <geometry>
                <cylinder radius="${tilt_lidar_base_radius}" length="${tilt_lidar_base_length}" />
            </geometry>
            <origin xyz="0 0 ${tilt_lidar_base_length/2}" rpy="0 0 0" />
            <material name="grey" />
        </visual>
    </link>

    <link name="tilt_lidar_link">
        <visual>
            <geometry>
                <cylinder radius="${rplidar_radius}" length="${rplidar_length}" />
            </geometry>
            <origin xyz="0 0 ${rplidar_sensor_height-rplidar_length}" rpy="0 0 0" />
            <material name="black" />
        </visual>
    </link>

    <link name="top_lidar_link">
        <visual>
            <geometry>
                <cylinder radius="${rplidar_radius}" length="${rplidar_length}" />
            </geometry>
            <origin xyz="0 0 ${rplidar_sensor_height-rplidar_length}" rpy="0 0 0" />
            <material name="black" />
        </visual>
    </link>        

    <link name="gps_link">
        <visual>
            <geometry>
                <cylinder radius="${gps_radius}" length="${gps_length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="dark_blue" />
        </visual>
        <!-- <xacro:box_inertia m="0.0001" w="0.0001" d="0.0001" h="0.0001" xyz="0 0 0"/> -->
    
    </link>

    <xacro:wheel_link prefix="right" pos="rear" rpy="0 0 0"/>
    <xacro:wheel_link prefix="left" pos="rear" rpy="0 0 0"  />

    <xacro:wheel_link_f prefix="right" pos="front" rpy="0 0 0"/>
    <xacro:wheel_link_f prefix="left" pos="front" rpy="0 0 0"/>

    <xacro:wheel_link prefix="right" pos="middle" rpy="0 0 0"/>
    <xacro:wheel_link prefix="left" pos="middle" rpy="0 0 0"/>

    <xacro:wheel_link_f prefix="right" pos="front_2" rpy="0 0 0"/>
    <xacro:wheel_link_f prefix="left" pos="front_2" rpy="0 0 0"/> 

    <xacro:wheel_link prefix="right" pos="rear_2" rpy="0 0 0"/>
    <xacro:wheel_link prefix="left" pos="rear_2" rpy="0 0 0"/>

    <xacro:wheel_link_f prefix="right" pos="front_4" rpy="0 0 0"/>
    <xacro:wheel_link_f prefix="left" pos="front_4" rpy="0 0 0"/> 

    <xacro:wheel_link prefix="right" pos="rear_4" rpy="0 0 0"/>
    <xacro:wheel_link prefix="left" pos="rear_4" rpy="0 0 0"/>

    <xacro:wheel_link_f prefix="right" pos="front_43" rpy="0 0 0"/>
    <xacro:wheel_link_f prefix="left" pos="front_43" rpy="0 0 0"/> 

    <xacro:wheel_link prefix="right" pos="rear_43" rpy="0 0 0"/>
    <xacro:wheel_link prefix="left" pos="rear_43" rpy="0 0 0"/>


    <!-- <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius/2}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="black" />
        </visual>
    </link> -->


    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="${-((base_length/2)-0.16)} 0 ${wheel_radius}" rpy="0 0 0" />
    </joint>

    <joint name="base_top_base_joint" type="fixed">
        <parent link="base_link" />
        <child link="top_base_link" />
        <origin xyz="${-(base_length-top_base_length)/2} 0 ${base_height}" rpy="0 0 0" />
    </joint>

    <joint name="base_tilt_lidar_base_joint" type="fixed">
        <parent link="base_link" />
        <child link="tilt_lidar_base_link" />
        <origin xyz="${base_tilt_lidar_base_x_offset} 0 ${base_height}" rpy="0 0 0" />
    </joint>

    <joint name="tilt_lidar_base_tilt_lidar_joint" type="fixed">
        <parent link="base_link" />
        <child link="tilt_lidar_link" />
        <origin xyz="${base_tilt_lidar_base_x_offset+rplidar_sensor_height * cos(degrees(60))} 0 ${base_height+tilt_lidar_base_length + rplidar_sensor_height * sin(degrees(60))}" rpy="0 ${radians(30)} 0" />
    </joint>

    <joint name="top_base_top_lidar_joint" type="fixed">
        <parent link="top_base_link" />
        <child link="top_lidar_link" />
        <origin xyz="${top_base_to_top_sensor_x_offset} 0 ${top_base_height + rplidar_sensor_height}" rpy="0 0 0" />
    </joint>

    <joint name="top_base_gps_joint" type="fixed">
        <parent link="top_base_link" />
        <child link="gps_link" />
        <origin xyz="${top_base_to_top_sensor_x_offset} 0 ${top_base_height + gps_sensor_height}" rpy="0 0 0" />
    </joint>

    <!-- <joint name="base_right_track_joint" type="fixed">
        <parent link="base_link" />
        <child link="right_track_link" />
        <origin xyz="0 ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
    </joint>

    <joint name="base_left_track_joint" type="fixed">
        <parent link="base_link" />
        <child link="left_track_link" />
        <origin xyz="0 ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
    </joint> -->



    <joint name="base_right_wheel_rear_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_rear_link" />
        <origin xyz="${-base_length/3.5} ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_rear_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_rear_link" />
        <origin xyz="${-base_length/3.5} ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- <joint name="base_caster_wheel_joint" type="fixed">
        <parent link="base_link" />
        <child link="caster_wheel_link" />
        <origin xyz="${(base_length/4) + 0.08} 0 ${-wheel_radius/2}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint> -->

    <joint name="base_right_wheel_front_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_front_link" />
        <origin xyz="${base_length/3.5} ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_front_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_front_link" />
        <origin xyz="${base_length/3.5} ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_middle_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_middle_link" />
        <origin xyz="0 ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_middle_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_middle_link" />
        <origin xyz="0 ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>


    <joint name="base_right_wheel_rear_4_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_rear_4_link" />
        <origin xyz="${-base_length/14} ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_rear_4_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_rear_4_link" />
        <origin xyz="${-base_length/14} ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_front_4_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_front_4_link" />
        <origin xyz="${base_length/14} ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_front_4_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_front_4_link" />
        <origin xyz="${base_length/14} ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_rear_2_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_rear_2_link" />
        <origin xyz="${-base_length/7} ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_rear_2_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_rear_2_link" />
        <origin xyz="${-base_length/7} ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_front_2_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_front_2_link" />
        <origin xyz="${base_length/7} ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_front_2_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_front_2_link" />
        <origin xyz="${base_length/7} ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_rear_43_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_rear_43_link" />
        <origin xyz="${-3*base_length/15} ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_rear_43_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_rear_43_link" />
        <origin xyz="${-3*base_length/15} ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_front_43_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_front_43_link" />
        <origin xyz="${3*base_length/15} ${-((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_front_43_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_front_43_link" />
        <origin xyz="${3*base_length/15} ${((base_width/2)+(wheel_length/2)+0.006)} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>
</robot>